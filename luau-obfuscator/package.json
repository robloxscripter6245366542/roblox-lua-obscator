{
  "name": "@ferret/luau-obfuscator",
  "version": "0.1.0",
  "description": "Production-quality source-to-source Luau obfuscator (AST-based, semantics-preserving).",
  "type": "module",
  "bin": {
    "luau-obfuscate": "dist/src/cli/cli.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "cli": "npm run build && node dist/cli/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "bench": "npm run build && node dist/bench/bench.js",
    "corpus": "npm run build && node dist/scripts/corpus.js"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
